// PAGE RÉUSSITES
// ══════════════════════════════════════════════════════════════
function PageReussites({ db }) {
  const today = formatDate(journeeLogique());
  const exToday = db.executions.filter(e => e.date === today && e.statut === 'Termine');
  const actifs = db.quotidiens.filter(q => q.statut === 'Actif').length
               + db.recurrents.filter(r => r.statut === 'Actif').length
               + db.longTerme.filter(l => l.statut === 'En cours').length;

  // Streak
  let streak = 0;
  const sortedEx = [...db.executions].sort((a,b) => new Date(b.ts)-new Date(a.ts));
  // Simplifié: compte les jours consécutifs avec au moins 1 exécution
  const exByDate = {};
  sortedEx.forEach(e => { if(e.statut==='Termine') exByDate[e.date] = true; });
  let d = new Date();
  while (exByDate[formatDate(d)]) { streak++; d.setDate(d.getDate()-1); }

  const kpis = [
    { val: exToday.length, label: 'Tâches réalisées', color: 'blue' },
    { val: actifs, label: 'Objectifs actifs', color: 'green' },
    { val: streak, label: 'Jours consécutifs 🔥', color: 'orange' },
    { val: db.ponctuels.filter(p=>p.statut==='Planifie').length, label: 'Événements à venir', color: 'red' },
  ];

  const JOURS_SEMAINE = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];

  return (
    <div>
      <div className="page-header">
        <h1 className="page-title">Réussites ✨</h1>
        <p className="page-subtitle">{today} · Ta progression</p>
      </div>

      {/* KPIs */}
      <div className="section-title">VUE D'ENSEMBLE</div>
      <div className="kpi-grid" style={{marginBottom:28}}>
        {kpis.map((k,i) => (
          <div key={i} className="kpi-card">
            <div className="kpi-val" style={{color:`var(--${k.color})`}}>{k.val}</div>
            <div className="kpi-label">{k.label}</div>
          </div>
        ))}
      </div>

      {/* Progression objectifs long terme */}
      {db.longTerme.filter(l=>l.statut==='En cours').length > 0 && (
        <>
          <div className="section-title">PROGRESSION — OBJECTIFS EN COURS</div>
          <div style={{display:'flex',flexDirection:'column',gap:10,marginBottom:28}}>
            {db.longTerme.filter(l=>l.statut==='En cours').map(lt => {
              const total = (lt.intermediaires?.length||0) + (lt.sousObjectifs?.length||0);
              const done = db.executions.filter(e=>e.nom===lt.nom&&e.statut==='Termine').length;
              const pct = total ? Math.min(100, Math.round(done/total*100)) : 0;
              return (
                <div key={lt.id} className="card card-body">
                  <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:10}}>
                    <span style={{fontWeight:600}}>{lt.nom}</span>
                    <span style={{fontFamily:'Syne',fontSize:20,fontWeight:800,color:'var(--green)'}}>{pct}%</span>
                  </div>
                  <div className="progress-bar">
                    <div className="progress-fill" style={{width:`${pct}%`,background:'var(--green)'}}/>
                  </div>
                </div>
              );
            })}
          </div>
        </>
      )}

      {/* Routines hebdo */}
      {db.quotidiens.filter(q=>q.statut==='Actif').length > 0 && (
        <>
          <div className="section-title">ROUTINES — SEMAINE EN COURS</div>
          <div className="card" style={{marginBottom:28}}>
            <div className="table-header" style={{gridTemplateColumns:'1fr repeat(7,32px)'}}>
              <span>Objectif</span>
              {JOURS_SEMAINE.map(j=><span key={j} style={{textAlign:'center'}}>{j}</span>)}
            </div>
            {db.quotidiens.filter(q=>q.statut==='Actif').map(q => {
              // Calculer les jours de la semaine en cours
              const now = new Date();
              const dayOfWeek = now.getDay(); // 0=dim
              const days = JOURS_SEMAINE.map((_, i) => {
                const d = new Date(now);
                d.setDate(now.getDate() - (dayOfWeek === 0 ? 6 : dayOfWeek - 1) + i);
                const ds = formatDate(d);
                const done = db.executions.some(e => e.nom===q.nom && e.date===ds && e.statut==='Termine');
                const isPast = d <= now;
                return { done, isPast };
              });
              return (
                <div key={q.id} className="table-row" style={{gridTemplateColumns:'1fr repeat(7,32px)',borderBottom:'1px solid var(--border)'}}>
                  <span style={{fontWeight:500}}>{q.nom}</span>
                  {days.map((d,i)=>(
                    <span key={i} style={{textAlign:'center',fontSize:14}}>
                      {d.done ? '✅' : d.isPast ? '–' : ''}
                    </span>
                  ))}
                </div>
              );
            })}
          </div>
        </>
      )}

      {/* Ponctuels prioritaires */}
      {db.ponctuels.filter(p=>p.statut==='Planifie').length > 0 && (
        <>
          <div className="section-title">ÉVÉNEMENTS À VENIR</div>
          <div className="card">
            <div className="table-header" style={{gridTemplateColumns:'1fr 120px 60px'}}>
              <span>Événement</span><span>Date</span><span>J-</span>
            </div>
            {db.ponctuels.filter(p=>p.statut==='Planifie').map(p => {
              const jMoins = p.dateRDV ? Math.ceil((new Date(p.dateRDV)-new Date())/(1000*60*60*24)) : '–';
              return (
                <div key={p.id} className="table-row" style={{gridTemplateColumns:'1fr 120px 60px'}}>
                  <span style={{fontWeight:500}}>{p.nom}</span>
                  <span style={{color:'var(--text2)',fontSize:13}}>{p.dateRDV}</span>
                  <span style={{fontWeight:700,color:jMoins<30?'var(--red)':'var(--text2)'}}>{jMoins}</span>
                </div>
              );
            })}
          </div>
        </>
      )}

      {actifs === 0 && db.executions.length === 0 && (
        <div className="card"><div className="empty">
          <div className="empty-icon">🌱</div>
          <div className="empty-text">Commence par ajouter des objectifs pour voir ta progression ici.</div>
        </div></div>
      )}
    </div>
  );
}

