// PAGE POIDS
// ══════════════════════════════════════════════════════════════
function PagePoids({ db, updateDB }) {
  const [poids, setPoids] = useState('');
  const [poidsObj, setPoidsObj] = useState(db.params?.poidsObjectif || '');

  const saisir = () => {
    const val = parseFloat(poids.replace(',','.'));
    if (isNaN(val)) { alert('Valeur invalide.'); return; }
    updateDB(d => {
      d.params = { ...d.params, poids: val };
      d.calories = d.calories || [];
      d.calories.push({
        id: genId('PD', d.calories),
        date: formatDate(journeeLogique()),
        type: 'Poids', valeur: val,
        ts: new Date().toISOString()
      });
    });
    setPoids('');
    alert(`✅ Poids ${val} kg enregistré !`);
  };

  const saveObjectif = () => {
    const val = parseFloat(poidsObj.replace(',','.'));
    if (isNaN(val)) return;
    updateDB(d => { d.params = { ...d.params, poidsObjectif: val }; });
    alert('✅ Objectif enregistré !');
  };

  const poidsActuel = db.params?.poids || '';
  const poidsObjectif = db.params?.poidsObjectif || '';
  const aPerdr = poidsActuel && poidsObjectif ? (poidsActuel - poidsObjectif).toFixed(1) : null;
  const pct = aPerdr && poidsActuel && poidsObjectif && poidsActuel > poidsObjectif
    ? Math.max(0, Math.min(100, Math.round((1 - aPerdr / (poidsActuel - poidsObjectif + aPerdr)) * 100)))
    : 0;

  const historique = (db.calories||[]).filter(c=>c.type==='Poids').slice(-10).reverse();

  return (
    <div style={{maxWidth:600}}>
      <div className="page-header">
        <h1 className="page-title">Poids & Déficit</h1>
        <p className="page-subtitle">Suivi par déficit calorique</p>
      </div>

      {/* KPIs */}
      <div className="kpi-grid" style={{marginBottom:24}}>
        <div className="kpi-card">
          <div className="kpi-val" style={{color:'var(--purple)'}}>{poidsActuel ? `${poidsActuel} kg` : '–'}</div>
          <div className="kpi-label">Poids actuel</div>
        </div>
        <div className="kpi-card">
          <div className="kpi-val" style={{color:'var(--green)'}}>{poidsObjectif ? `${poidsObjectif} kg` : '–'}</div>
          <div className="kpi-label">Objectif</div>
        </div>
        <div className="kpi-card">
          <div className="kpi-val" style={{color:'var(--red)'}}>{aPerdr ? `${aPerdr} kg` : '–'}</div>
          <div className="kpi-label">À perdre</div>
        </div>
      </div>

      {/* Barre progression */}
      {aPerdr && (
        <div className="card card-body" style={{marginBottom:24}}>
          <div style={{display:'flex',justifyContent:'space-between',marginBottom:8}}>
            <span style={{fontSize:13,color:'var(--text2)'}}>Progression</span>
            <span style={{fontSize:13,fontWeight:700,color:'var(--purple)'}}>{pct}%</span>
          </div>
          <div className="progress-bar" style={{height:12}}>
            <div className="progress-fill" style={{width:`${pct}%`,background:'linear-gradient(90deg,var(--purple),var(--blue))'}}/>
          </div>
        </div>
      )}

      {/* Saisir poids */}
      <div className="section-title">SAISIR LE POIDS DU JOUR</div>
      <div className="card card-body" style={{marginBottom:24}}>
        <div className="form-row">
          <div className="form-group">
            <label className="form-label">Poids aujourd'hui (kg)</label>
            <input className="form-input" type="number" step="0.1" placeholder="ex: 70.5"
              value={poids} onChange={e => setPoids(e.target.value)} />
          </div>
          <div className="form-group">
            <label className="form-label">Objectif (kg)</label>
            <input className="form-input" type="number" step="0.1" placeholder="ex: 65"
              value={poidsObj} onChange={e => setPoidsObj(e.target.value)} />
          </div>
        </div>
        <div style={{display:'flex',gap:10}}>
          <button className="btn btn-primary" style={{flex:2}} onClick={saisir}>⚖️ Enregistrer</button>
          <button className="btn btn-ghost" style={{flex:1}} onClick={saveObjectif}>Sauver objectif</button>
        </div>
      </div>

      {/* Historique */}
      {historique.length > 0 && (
        <>
          <div className="section-title">HISTORIQUE</div>
          <div className="card">
            <div className="table-header" style={{gridTemplateColumns:'1fr 1fr'}}>
              <span>Date</span><span>Poids</span>
            </div>
            {historique.map((h,i) => (
              <div key={i} className="table-row" style={{gridTemplateColumns:'1fr 1fr'}}>
                <span style={{color:'var(--text2)'}}>{h.date}</span>
                <span style={{fontWeight:600,color:'var(--purple)'}}>{h.valeur} kg</span>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  );
}

