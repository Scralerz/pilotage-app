// PAGE VUE DU JOUR
// ══════════════════════════════════════════════════════════════
function PageVueJour({ db, updateDB }) {
  const today = formatDate(journeeLogique());
  const [date, setDate] = useState(today);

  // Construire le planning à partir des BD
  const planning = [];

  // Ajouter les quotidiens actifs
  db.quotidiens.filter(q => q.statut === 'Actif').forEach((q, i) => {
    planning.push({
      id: q.id, nom: q.nom, dur: q.duree ? `${q.duree} min` : '',
      cat: 'Quotidien', statut: 'À faire', color: 'blue', ordre: 10 + i
    });
  });

  // Ajouter les récurrents actifs
  db.recurrents.filter(r => r.statut === 'Actif').forEach((r, i) => {
    planning.push({
      id: r.id, nom: r.nom, dur: r.duree ? `${r.duree} min` : '',
      heure: r.heure, cat: 'Récurrent', statut: 'À faire', color: 'orange', ordre: 20 + i
    });
  });

  const retirerBloc = (id) => {
    if (!confirm('Retirer ce bloc pour cette date uniquement ?')) return;
    updateDB(d => {
      d.exceptions.push({
        id: genId('EXC', d.exceptions),
        date, blocId: id, action: 'Retire',
        ts: new Date().toISOString()
      });
    });
  };

  const retires = new Set(
    db.exceptions.filter(e => e.date === date).map(e => e.blocId)
  );

  const visible = planning.filter(p => !retires.has(p.id)).sort((a,b) => a.ordre - b.ordre);

  const catColor = {
    'Quotidien': 'blue', 'Récurrent': 'orange', 'Long terme': 'green',
    'Ponctuel': 'red', 'Alimentation': 'teal'
  };

  return (
    <div>
      <div className="page-header">
        <h1 className="page-title">Vue du jour</h1>
        <p className="page-subtitle">Planning complet · {date}</p>
      </div>

      {/* Sélecteur date */}
      <div style={{display:'flex',gap:10,marginBottom:24,alignItems:'center',flexWrap:'wrap'}}>
        <input type="date" className="form-input" style={{width:'auto'}}
          value={date.split('/').reverse().join('-')}
          onChange={e => setDate(e.target.value.split('-').reverse().join('/'))} />
        <button className="btn btn-ghost btn-sm" onClick={() => setDate(today)}>Aujourd'hui</button>
      </div>

      {/* Planning */}
      <div className="section-title">PLANNING</div>
      {visible.length === 0 ? (
        <div className="card"><div className="empty"><div className="empty-icon">📭</div><div className="empty-text">Aucun bloc pour cette date</div></div></div>
      ) : (
        <div className="card">
          <div className="table-header" style={{gridTemplateColumns:'1fr 100px 80px 36px'}}>
            <span>Bloc</span><span>Catégorie</span><span>Durée</span><span/>
          </div>
          {visible.map((p, i) => (
            <div key={p.id} className="table-row" style={{gridTemplateColumns:'1fr 100px 80px 36px'}}>
              <div style={{display:'flex',alignItems:'center',gap:10}}>
                <div style={{width:3,height:24,borderRadius:2,background:`var(--${catColor[p.cat]||'blue'})`}}/>
                <span style={{fontWeight:500}}>{p.nom}</span>
              </div>
              <span className={`badge badge-${catColor[p.cat]||'blue'}`}>{p.cat}</span>
              <span style={{fontSize:13,color:'var(--text2)'}}>{p.dur}</span>
              <button onClick={() => retirerBloc(p.id)}
                style={{background:'none',border:'none',color:'var(--text3)',cursor:'pointer',fontSize:16,padding:4}}>
                ✕
              </button>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

