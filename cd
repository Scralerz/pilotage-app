      </div>

      <div style={{display:'flex',gap:8,marginBottom:20}}>
        <button className={`btn btn-sm ${tab==='aliments'?'btn-primary':'btn-ghost'}`} onClick={() => setTab('aliments')}>Aliments</button>
        <button className={`btn btn-sm ${tab==='recettes'?'btn-primary':'btn-ghost'}`} onClick={() => setTab('recettes')}>Recettes</button>
        <button className={`btn btn-sm ${tab==='ajouterA'?'btn-primary':'btn-ghost'}`} onClick={() => setTab('ajouterA')}>+ Aliment</button>
      </div>

      {tab === 'aliments' && (
        db.aliments.length === 0 ? (
          <div className="card"><div className="empty"><div className="empty-icon">🥦</div><div className="empty-text">Aucun aliment enregistré.</div></div></div>
        ) : (
          <div className="card">
            <div className="table-header" style={{gridTemplateColumns:'1fr 80px 80px 80px 80px'}}>
              <span>Aliment</span><span>Kcal</span><span>Prot.</span><span>Gluc.</span><span>Lip.</span>
            </div>
            {db.aliments.map(a => (
              <div key={a.id} className="table-row" style={{gridTemplateColumns:'1fr 80px 80px 80px 80px'}}>
                <div>
                  <div style={{fontWeight:500}}>{a.nom}</div>
                  {a.categorie && <span style={{fontSize:11,color:'var(--text3)'}}>{a.categorie}</span>}
                </div>
                <span style={{color:'var(--orange)',fontWeight:600}}>{a.kcal}</span>
                <span style={{color:'var(--blue)'}}>{a.proteines}g</span>
                <span style={{color:'var(--amber)'}}>{a.glucides}g</span>
                <span style={{color:'var(--teal)'}}>{a.lipides}g</span>
              </div>
            ))}
          </div>
        )
      )}

      {tab === 'ajouterA' && (
        <div className="card card-body" style={{maxWidth:480}}>
          <div className="form-group">
            <label className="form-label">Nom de l'aliment</label>
            <input className="form-input" placeholder="ex: Poulet rôti"
              value={formA.nom} onChange={e => setFormA({...formA, nom:e.target.value})} />
          </div>
          <div className="form-row">
            <div className="form-group">
              <label className="form-label">Kcal / 100g</label>
              <input className="form-input" type="number"
                value={formA.kcal} onChange={e => setFormA({...formA, kcal:e.target.value})} />
            </div>
            <div className="form-group">
              <label className="form-label">Catégorie</label>
              <input className="form-input" placeholder="Protéines, Légumes..."
                value={formA.categorie} onChange={e => setFormA({...formA, categorie:e.target.value})} />
            </div>
          </div>
          <div className="form-row">
            <div className="form-group">
              <label className="form-label">Protéines (g)</label>
              <input className="form-input" type="number"
                value={formA.proteines} onChange={e => setFormA({...formA, proteines:e.target.value})} />
            </div>
            <div className="form-group">
              <label className="form-label">Glucides (g)</label>
              <input className="form-input" type="number"
                value={formA.glucides} onChange={e => setFormA({...formA, glucides:e.target.value})} />
            </div>
          </div>
          <div className="form-group">
            <label className="form-label">Lipides (g)</label>
            <input className="form-input" type="number" style={{maxWidth:160}}
              value={formA.lipides} onChange={e => setFormA({...formA, lipides:e.target.value})} />
          </div>
          <button className="btn btn-green" onClick={ajouterAliment}>✅ Ajouter l'aliment</button>
        </div>
      )}

      {tab === 'recettes' && (
        <div className="card"><div className="empty"><div className="empty-icon">🍽️</div><div className="empty-text">La gestion des recettes arrive bientôt !</div></div></div>
      )}
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// PAGE CALORIES
// ══════════════════════════════════════════════════════════════
function PageCalories({ db, updateDB }) {
  const today = formatDate(journeeLogique());
  const [date, setDate] = useState(today);
  const [form, setForm] = useState({ aliment:'', type:'Aliment', qte:'', kcal:'', repas:'Petit-dejeuner' });

  const repas = ['Petit-dejeuner','Dejeuner','Diner','Collation'];
  const objectifKcal = 1800; // Depuis PARAMETRES

  const joursEntrees = (db.calories||[]).filter(c => c.date===date && c.type!=='Poids');
  const totalKcal = joursEntrees.reduce((s,e) => s+(parseFloat(e.kcal)||0), 0);
  const deficit = objectifKcal - totalKcal;

  const ajouter = () => {
    if (!form.aliment) { alert('Nom obligatoire.'); return; }
    updateDB(d => {
      d.calories = d.calories || [];
      d.calories.push({
        id: genId('CAL', d.calories),
        date, nom: form.aliment, type: form.type,
        qte: form.qte, kcal: form.kcal, repas: form.repas,
        ts: new Date().toISOString()
      });
    });
    setForm({ ...form, aliment:'', qte:'', kcal:'' });
  };

  const repasGroups = repas.map(r => ({
    label: r,
    items: joursEntrees.filter(e => e.repas === r),
    total: joursEntrees.filter(e=>e.repas===r).reduce((s,e)=>s+(parseFloat(e.kcal)||0),0)
  }));

  return (
    <div>
      <div className="page-header">
        <h1 className="page-title">Calories</h1>
        <p className="page-subtitle">Suivi journalier · logique 5h → 4h59</p>
      </div>

      {/* Sélecteur date */}
      <div style={{display:'flex',gap:10,marginBottom:20,alignItems:'center',flexWrap:'wrap'}}>
        <input type="date" className="form-input" style={{width:'auto'}}
          value={date.split('/').reverse().join('-')}
          onChange={e => setDate(e.target.value.split('-').reverse().join('/'))} />
        <button className="btn btn-ghost btn-sm" onClick={() => setDate(today)}>Aujourd'hui</button>
      </div>

      {/* Récapitulatif */}
      <div className="kpi-grid" style={{marginBottom:20}}>
        <div className="kpi-card">
          <div className="kpi-val" style={{color:'var(--orange)'}}>{objectifKcal}</div>
          <div className="kpi-label">Objectif kcal</div>
        </div>
        <div className="kpi-card">
          <div className="kpi-val" style={{color:'var(--red)'}}>{Math.round(totalKcal)}</div>
          <div className="kpi-label">Ingérées</div>
        </div>
        <div className="kpi-card">
          <div className="kpi-val" style={{color:deficit>0?'var(--green)':'var(--red)'}}>
            {deficit>0?'+':''}{Math.round(deficit)}
          </div>
          <div className="kpi-label">Déficit</div>
        </div>
      </div>

      {/* Barre */}
      <div className="card card-body" style={{marginBottom:24}}>
        <div style={{display:'flex',justifyContent:'space-between',marginBottom:8}}>
          <span style={{fontSize:13,color:'var(--text2)'}}>Remplissage</span>
          <span style={{fontSize:13,fontWeight:700,color:'var(--orange)'}}>
            {Math.round(totalKcal/objectifKcal*100)}%
          </span>
        </div>
        <div className="progress-bar" style={{height:12}}>
          <div className="progress-fill" style={{
            width:`${Math.min(100,totalKcal/objectifKcal*100)}%`,
            background: totalKcal>objectifKcal ? 'var(--red)' : 'var(--orange)'
          }}/>
        </div>
      </div>

      {/* Repas */}
      {repasGroups.map(g => (
        <div key={g.label} style={{marginBottom:20}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:8}}>
            <div className="section-title" style={{margin:0}}>{g.label.toUpperCase()}</div>
            <span style={{fontSize:13,fontWeight:600,color:'var(--orange)'}}>{g.total} kcal</span>
          </div>
          {g.items.length > 0 && (
            <div className="card" style={{marginBottom:8}}>
              {g.items.map((e,i) => (
                <div key={e.id} className="table-row" style={{gridTemplateColumns:'1fr 60px 80px'}}>
                  <span style={{fontWeight:500}}>{e.nom}</span>
                  <span style={{color:'var(--text3)',fontSize:13}}>{e.qte}g</span>
                  <span style={{fontWeight:600,color:'var(--orange)',fontSize:13}}>{e.kcal} kcal</span>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}

      {/* Ajouter */}
      <div className="section-title">AJOUTER UN ALIMENT</div>
      <div className="card card-body">
        <div className="form-group">
          <label className="form-label">Repas</label>
          <select className="form-select" value={form.repas} onChange={e=>setForm({...form,repas:e.target.value})}>
            {repas.map(r=><option key={r}>{r}</option>)}
          </select>
        </div>
        <div className="form-group">
          <label className="form-label">Aliment / Recette</label>
          <input className="form-input" placeholder="Nom..."
            value={form.aliment} onChange={e=>setForm({...form,aliment:e.target.value})}/>
        </div>
        <div className="form-row">
          <div className="form-group">
            <label className="form-label">Quantité (g)</label>
            <input className="form-input" type="number"
              value={form.qte} onChange={e=>setForm({...form,qte:e.target.value})}/>
          </div>
          <div className="form-group">
            <label className="form-label">Kcal</label>
            <input className="form-input" type="number"
              value={form.kcal} onChange={e=>setForm({...form,kcal:e.target.value})}/>
          </div>
        </div>
        <button className="btn btn-orange" style={{background:'var(--orange)',color:'white'}} onClick={ajouter}>+ Ajouter</button>
      </div>
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// PAGE ARCHIVES
// ══════════════════════════════════════════════════════════════
function PageArchives({ db }) {
  const archivesQ = db.quotidiens.filter(q => q.statut === 'Clos');
  const archivesLT = db.longTerme.filter(l => l.statut === 'Termine');
  const archivesPT = db.ponctuels.filter(p => p.statut === 'Termine');

  const total = archivesQ.length + archivesLT.length + archivesPT.length;

  return (
    <div>
      <div className="page-header">
        <h1 className="page-title">Archives</h1>
        <p className="page-subtitle">{total} éléments terminés ou clos</p>
      </div>

      {total === 0 ? (
        <div className="card"><div className="empty">
          <div className="empty-icon">🗂️</div>
          <div className="empty-text">Rien ici pour l'instant. Continue à progresser !</div>
        </div></div>
      ) : (
        <>
          {archivesQ.length > 0 && (
            <>
              <div className="section-title">QUOTIDIENS CLOS</div>
              <div className="card" style={{marginBottom:20}}>
                {archivesQ.map(q => (
                  <div key={q.id} className="table-row" style={{gridTemplateColumns:'1fr auto'}}>
                    <span style={{fontWeight:500,color:'var(--text2)'}}>{q.nom}</span>
                    <span className="badge badge-blue">Clos</span>
                  </div>
                ))}
              </div>
            </>
          )}
          {archivesLT.length > 0 && (
            <>
              <div className="section-title">LONG TERME TERMINÉS</div>
              <div className="card" style={{marginBottom:20}}>
                {archivesLT.map(l => (
                  <div key={l.id} className="table-row" style={{gridTemplateColumns:'1fr auto'}}>
                    <span style={{fontWeight:500}}>{l.nom}</span>
                    <span className="badge badge-green">100%</span>
                  </div>
                ))}
              </div>
            </>
          )}
          {archivesPT.length > 0 && (
            <>
              <div className="section-title">PONCTUELS TERMINÉS</div>
              <div className="card">
                {archivesPT.map(p => (
                  <div key={p.id} className="table-row" style={{gridTemplateColumns:'1fr 120px auto'}}>
                    <span style={{fontWeight:500}}>{p.nom}</span>
                    <span style={{color:'var(--text3)',fontSize:13}}>{p.dateRDV}</span>
                    <span className="badge badge-green">Terminé</span>
                  </div>
                ))}
              </div>
            </>
          )}
        </>
      )}
    </div>
  );
}

