// PAGE AJOUTER UN OBJECTIF
// ══════════════════════════════════════════════════════════════
function PageAjouter({ db, updateDB, navigate }) {
  const [type, setType] = useState('Quotidien');
  const [form, setForm] = useState({
    nom:'', duree:'', dateDebut:'', dateFin:'', heure:'',
    frequence:'Toutes les semaines', datesExclues:'',
    position:'Debut de journee', refBloc:'',
    statut:'En cours', jours:['Tous'],
    sousObjectifs:[{nom:'',duree:'',jours:'Tous'},{nom:'',duree:'',jours:'Tous'},{nom:'',duree:'',jours:'Tous'}],
    intermediaires:['','',''],
    dateRDV:'', heureRDV:'', heureDepart:'', lieu:'', infos:'', typePrep:'Aucune',
    nomRepas:'', heureRepas:'', dureeRepas:'', posAlim:'Debut de journee', refAlim:'',
    useHeureFix: true,
  });

  const setF = (k, v) => setForm(prev => ({ ...prev, [k]: v }));

  const TYPES = [
    { id:'Quotidien',    label:'🔁 Quotidien',    color:'blue'   },
    { id:'Recurrent',   label:'📅 Récurrent',    color:'orange' },
    { id:'Long terme',  label:'🎯 Long terme',   color:'green'  },
    { id:'Ponctuel',    label:'📌 Ponctuel',     color:'red'    },
    { id:'Alimentation',label:'🥗 Alimentation', color:'teal'   },
  ];

  const JOURS = ['Tous','Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];

  const toggleJour = (j) => {
    if (j === 'Tous') { setF('jours', ['Tous']); return; }
    const curr = form.jours.filter(x => x !== 'Tous');
    if (curr.includes(j)) {
      const next = curr.filter(x => x !== j);
      setF('jours', next.length ? next : ['Tous']);
    } else {
      setF('jours', [...curr, j]);
    }
  };

  // Options position
  const posOptions = ['Debut de journee','Fin de journee',
    ...db.quotidiens.filter(q=>q.statut==='Actif').map(q=>q.nom),
    ...db.longTerme.filter(l=>l.statut==='En cours').map(l=>l.nom),
  ];

  const valider = () => {
    if (!form.nom.trim()) { alert('Le nom est obligatoire.'); return; }

    updateDB(d => {
      switch(type) {
        case 'Quotidien':
          d.quotidiens.push({
            id: genId('QT', d.quotidiens),
            nom: form.nom, duree: form.duree,
            dateDebut: form.dateDebut, statut: 'Actif',
            position: form.position, refBloc: form.refBloc,
            jours: form.jours,
            sousObjectifs: form.sousObjectifs.filter(s => s.nom.trim()),
          });
          break;
        case 'Recurrent':
          d.recurrents.push({
            id: genId('RC', d.recurrents),
            nom: form.nom, duree: form.duree,
            dateDebut: form.dateDebut, dateFin: form.dateFin,
            heure: form.heure, frequence: form.frequence,
            datesExclues: form.datesExclues,
            position: form.position, refBloc: form.refBloc,
            jours: form.jours, statut: 'Actif',
          });
          break;
        case 'Long terme':
          d.longTerme.push({
            id: genId('LT', d.longTerme),
            nom: form.nom, duree: form.duree,
            dateDebut: form.dateDebut, statut: form.statut,
            position: form.position, refBloc: form.refBloc,
            intermediaires: form.intermediaires.filter(i => i.trim()),
            sousObjectifs: form.sousObjectifs.filter(s => s.nom.trim()),
          });
          break;
        case 'Ponctuel':
          d.ponctuels.push({
            id: genId('PT', d.ponctuels),
            nom: form.nom, dateRDV: form.dateRDV,
            heureRDV: form.heureRDV, heureDepart: form.heureDepart,
            lieu: form.lieu, infos: form.infos,
            typePrep: form.typePrep, statut: 'Planifie',
          });
          break;
        case 'Alimentation':
          // Repas dans le planning (pas une base d'aliments)
          d.executions.push({
            id: genId('AL', d.executions),
            type: 'Alimentation', nom: form.nomRepas,
            heure: form.useHeureFix ? form.heureRepas : '',
            duree: form.useHeureFix ? form.dureeRepas : '',
            position: !form.useHeureFix ? form.posAlim : '',
            refBloc: !form.useHeureFix ? form.refAlim : '',
            statut: 'Actif',
          });
          break;
      }
    });

    alert(`✅ ${type} ajouté !`);
    setForm({ ...form, nom:'', duree:'', dateDebut:'', dateFin:'', heure:'',
      datesExclues:'', sousObjectifs:[{nom:'',duree:'',jours:'Tous'},{nom:'',duree:'',jours:'Tous'},{nom:'',duree:'',jours:'Tous'}],
      intermediaires:['','',''], dateRDV:'', heureRDV:'', lieu:'', infos:'', nomRepas:'', heureRepas:'', dureeRepas:'',
    });
  };

  return (
    <div style={{maxWidth:640}}>
      <div className="page-header">
        <h1 className="page-title">Ajouter un objectif</h1>
        <p className="page-subtitle">Choisis le type puis remplis le formulaire</p>
      </div>

      {/* Type tabs */}
      <div className="type-tabs">
        {TYPES.map(t => (
          <button key={t.id} className="type-tab"
            style={{
              background: type===t.id ? `var(--${t.color})` : `var(--${t.color}-l)`,
              color: type===t.id ? 'white' : `var(--${t.color})`,
              borderColor: type===t.id ? `var(--${t.color})` : 'transparent',
            }}
            onClick={() => setType(t.id)}>
            {t.label}
          </button>
        ))}
      </div>

      <div className="card card-body" style={{display:'flex',flexDirection:'column',gap:4}}>

        {/* ── COMMUN ── */}
        <div className="form-group">
          <label className="form-label">Nom</label>
          <input className="form-input" placeholder={`Nom de l'objectif...`}
            value={form.nom} onChange={e => setF('nom', e.target.value)} />
        </div>

        {type !== 'Alimentation' && type !== 'Ponctuel' && (
          <div className="form-row">
            <div className="form-group">
              <label className="form-label">Durée (min)</label>
              <input className="form-input" type="number" placeholder="ex: 45"
                value={form.duree} onChange={e => setF('duree', e.target.value)} />
            </div>
            <div className="form-group">
              <label className="form-label">Date de début</label>
              <input className="form-input" type="date"
                value={form.dateDebut} onChange={e => setF('dateDebut', e.target.value)} />
            </div>
          </div>
        )}

        {/* ── POSITION (Quotidien, Récurrent, Long terme) ── */}
        {['Quotidien','Recurrent','Long terme'].includes(type) && (
          <>
            <div className="divider"/>
            <div className="section-title">POSITION DANS LE PLANNING</div>
            <div className="form-row">
              <div className="form-group">
                <label className="form-label">Avant / Après</label>
                <select className="form-select"
                  value={form.position} onChange={e => setF('position', e.target.value)}>
                  <option>Debut de journee</option>
                  <option>Fin de journee</option>
                  <option>Avant</option>
                  <option>Apres</option>
                </select>
              </div>
              {['Avant','Apres'].includes(form.position) && (
                <div className="form-group">
                  <label className="form-label">Quel élément</label>
                  <select className="form-select"
                    value={form.refBloc} onChange={e => setF('refBloc', e.target.value)}>
                    <option value="">Choisir...</option>
                    {posOptions.slice(2).map(o => <option key={o}>{o}</option>)}
                  </select>
                </div>
              )}
            </div>
          </>
        )}

        {/* ── JOURS (Quotidien, Récurrent) ── */}
        {['Quotidien','Recurrent'].includes(type) && (
          <>
            <div className="divider"/>
            <div className="section-title">JOURS ACTIFS</div>
            <div className="form-group">
              <div className="day-picker">
                {JOURS.map(j => (
                  <button key={j} className={`day-btn ${form.jours.includes(j) ? 'active' : ''}`}
                    onClick={() => toggleJour(j)}>{j.slice(0,3)}</button>
                ))}
              </div>
            </div>
          </>
        )}

        {/* ── SOUS-OBJECTIFS (Quotidien) ── */}
        {type === 'Quotidien' && (
          <>
            <div className="divider"/>
            <div className="section-title">SOUS-OBJECTIFS (optionnel)</div>
            {form.sousObjectifs.map((so, i) => (
              <div key={i} className="form-row" style={{marginBottom:10}}>
                <input className="form-input" placeholder={`Sous-objectif ${i+1}...`}
                  value={so.nom} onChange={e => {
                    const next = [...form.sousObjectifs];
                    next[i] = { ...next[i], nom: e.target.value };
                    setF('sousObjectifs', next);
                  }} />
                <input className="form-input" type="number" placeholder="Durée (min)"
                  value={so.duree} onChange={e => {
                    const next = [...form.sousObjectifs];
                    next[i] = { ...next[i], duree: e.target.value };
                    setF('sousObjectifs', next);
                  }} />
              </div>
            ))}
          </>
        )}

        {/* ── RÉCURRENT ── */}
        {type === 'Recurrent' && (
          <>
            <div className="divider"/>
            <div className="section-title">PARAMÈTRES RÉCURRENCE</div>
            <div className="form-row">
              <div className="form-group">
                <label className="form-label">Date de fin</label>
                <input className="form-input" type="date"
                  value={form.dateFin} onChange={e => setF('dateFin', e.target.value)} />
              </div>
              <div className="form-group">
                <label className="form-label">Heure</label>
                <input className="form-input" type="time"
                  value={form.heure} onChange={e => setF('heure', e.target.value)} />
              </div>
            </div>
            <div className="form-group">
              <label className="form-label">Fréquence</label>
              <select className="form-select"
                value={form.frequence} onChange={e => setF('frequence', e.target.value)}>
                <option>Toutes les semaines</option>
                <option>1 semaine sur 2</option>
                <option>1 semaine sur 3</option>
                <option>1 semaine sur 4</option>
              </select>
            </div>
            <div className="form-group">
              <label className="form-label">Dates exclues (optionnel)</label>
              <input className="form-input" placeholder="ex: 22/12/2025-05/01/2026, 15/02-28/02"
                value={form.datesExclues} onChange={e => setF('datesExclues', e.target.value)} />
            </div>
          </>
        )}

        {/* ── LONG TERME ── */}
        {type === 'Long terme' && (
          <>
            <div className="divider"/>
            <div className="section-title">STRUCTURE</div>
            <div className="form-group">
              <label className="form-label">Statut</label>
              <select className="form-select"
                value={form.statut} onChange={e => setF('statut', e.target.value)}>
                <option>En cours</option>
                <option>En pause</option>
                <option>Termine</option>
              </select>
            </div>
            <div className="section-title" style={{marginTop:8}}>Objectifs intermédiaires (optionnel)</div>
            {form.intermediaires.map((inter, i) => (
              <div key={i} className="form-group" style={{marginBottom:10}}>
                <input className="form-input" placeholder={`Intermédiaire ${i+1}...`}
                  value={inter} onChange={e => {
                    const next = [...form.intermediaires];
                    next[i] = e.target.value;
                    setF('intermediaires', next);
                  }} />
              </div>
            ))}
            <div className="section-title">Sous-objectifs (optionnel)</div>
            {form.sousObjectifs.map((so, i) => (
              <div key={i} className="form-group" style={{marginBottom:10}}>
                <input className="form-input" placeholder={`Sous-objectif ${i+1}...`}
                  value={so.nom} onChange={e => {
                    const next = [...form.sousObjectifs];
                    next[i] = { ...next[i], nom: e.target.value };
                    setF('sousObjectifs', next);
                  }} />
              </div>
            ))}
          </>
        )}

        {/* ── PONCTUEL ── */}
        {type === 'Ponctuel' && (
          <>
            <div className="divider"/>
            <div className="section-title">DÉTAILS DE L'ÉVÉNEMENT</div>
            <div className="form-row">
              <div className="form-group">
                <label className="form-label">Date du RDV</label>
                <input className="form-input" type="date"
                  value={form.dateRDV} onChange={e => setF('dateRDV', e.target.value)} />
              </div>
              <div className="form-group">
                <label className="form-label">Heure RDV</label>
                <input className="form-input" type="time"
                  value={form.heureRDV} onChange={e => setF('heureRDV', e.target.value)} />
              </div>
            </div>
            <div className="form-row">
              <div className="form-group">
                <label className="form-label">Heure de départ</label>
                <input className="form-input" type="time"
                  value={form.heureDepart} onChange={e => setF('heureDepart', e.target.value)} />
              </div>
              <div className="form-group">
                <label className="form-label">Type de préparation</label>
                <select className="form-select"
                  value={form.typePrep} onChange={e => setF('typePrep', e.target.value)}>
                  <option>Aucune</option>
                  <option>1 semaine avant</option>
                  <option>2 semaines avant</option>
                  <option>3 semaines avant</option>
                  <option>Date specifique</option>
                  <option>Recurrente</option>
                </select>
              </div>
            </div>
            <div className="form-group">
              <label className="form-label">Lieu / Adresse</label>
              <input className="form-input" placeholder="Saisir le lieu..."
                value={form.lieu} onChange={e => setF('lieu', e.target.value)} />
            </div>
            <div className="form-group">
              <label className="form-label">Infos complémentaires</label>
              <input className="form-input" placeholder="Notes, documents à apporter..."
                value={form.infos} onChange={e => setF('infos', e.target.value)} />
            </div>
          </>
        )}

        {/* ── ALIMENTATION ── */}
        {type === 'Alimentation' && (
          <>
            <div className="form-group">
              <label className="form-label">Nom du repas</label>
              <input className="form-input" placeholder="ex: Déjeuner, Dîner, Collation..."
                value={form.nomRepas} onChange={e => setF('nomRepas', e.target.value)} />
            </div>
            <div className="divider"/>
            <div className="section-title">PLACEMENT DANS LE PLANNING</div>
            <div style={{display:'flex',gap:8,marginBottom:16}}>
